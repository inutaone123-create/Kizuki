{
  "name": "kizuki-desktop",
  "version": "1.0.0",
  "description": "Kizuki - カンバン＆イシュー管理デスクトップアプリ",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.inutaone123.kizuki",
    "productName": "Kizuki",
    "directories": {
      "output": "build/electron-dist"
    },
    "files": [
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/kizuki-server",
        "to": "kizuki-server",
        "filter": ["**/*"]
      }
    ],
    "forceCodeSigning": false,
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "license": "MIT"
}
